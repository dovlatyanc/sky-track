{
  "name": "sky-track",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:front": "vite",
    "dev:back": "cd backend && bun run dev",
    "dev": "concurrently -n FRONT,BACK -c blue,green \"bun run dev:front\" \"bun run dev:back\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test-ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test-cov": "vitest run --coverage"
  },
