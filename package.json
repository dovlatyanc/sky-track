    "@tanstack/react-query": "^5.83.0",
    "@trpc/client": "^11.5.1",
    "@trpc/react-query": "^11.5.1",
    "@turf/turf": "^7.2.0",
    "axios": "^1.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
